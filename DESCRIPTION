Package: EcoNiche
Type: Package
Title: Community Niche Position and Width Estimation Tools
Version: 0.9.0
Authors@R: c(
    person("Shuotao", "Zhou", , "zhoushuotao@stu.hunau.edu.cn", role = c("aut", "cre")),
